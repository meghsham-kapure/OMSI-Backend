{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API with Nodemon",
      "runtimeExecutable": "nodemon",
      "runtimeArgs": [
        "src/main.js"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/node_modules/**"
      ],
      "envFile": "${workspaceFolder}/.env",
      "restart": true,
      "outputCapture": "std",
      "stopOnEntry": false
    }
  ]
}
